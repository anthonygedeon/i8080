  }

  case 0xE4:
    if (!state->Flag.p)
    {
      state->cycle += 6;
      call(state);
    }
    else
    {
      state->Register.pc += 2;
    }
    break;

  case 0xE5:
    stack_push(state, state->Register.h, state->Register.l);
    break; // PUSH H

  case 0xE6:
    ani(state);
    break;

  case 0xE7:
    rst(state, 0x20);
    break;

  case 0xE8:
    if (state->Flag.p)
    {
      state->cycle += 6;
      ret(state);
    }
    break;

  case 0xE9:
    state->Register.pc = state->Register.hl;
    break;

  case 0xEA:
    if (state->Flag.p == 1)
      jmp(state);
    else
      state->Register.pc += 2;
    break;

  case 0xEB:
  {
    u16 tmp = state->Register.hl;
    state->Register.hl = state->Register.de;
    state->Register.de = tmp;
    break;
  }

  case 0xEC:
    if (state->Flag.p)
    {
      state->cycle += 6;
      call(state);
    }
    else
    {
      state->Register.pc += 2;
    }
    break;

  case 0xEE:
    xri(state);
    break;

  case 0xEF:
    rst(state, 0x28);
    break;

  case 0xF0:
    if (!state->Flag.s)
    {
      state->cycle += 6;
      ret(state);
    }
    break;

  case 0xF2:
    if (!state->Flag.s)
      jmp(state);
    else
      state->Register.pc += 2;
    break;

  case 0xF3:
    state->inte = false;
    break;

  case 0xF4:
    if (!state->Flag.s)
    {
      state->cycle += 6;
      call(state);
    }
    else
    {
      state->Register.pc += 2;
    }
    break;

  case 0xF5:
    push_psw(state);
    break;

  case 0xF6:
    ori(state);
    break;

  case 0xF7:
    rst(state, 0x30);
    break;

  case 0xF8:
    if (state->Flag.s)
    {
      state->cycle += 6;
      ret(state);
    }
    break;

  case 0xF9:
    state->Register.sp = state->Register.hl;
    break;

  case 0xFA:
    if (state->Flag.s)
      jmp(state);
    else
      state->Register.pc += 2;
    break;

  case 0xFB:
    state->inte = true;
    break;

  case 0xFC:
    if (state->Flag.s)
    {
      state->cycle += 6;
      call(state);
    }
    else
    {
      state->Register.pc += 2;
    }
    break;

  case 0xFE:
    cpi(state);
    break;

  case 0xFF:
    rst(state, 0x38);
    break;

  // POP instructions
  case 0xC1:
    stack_pop(state, &state->Register.b, &state->Register.c);
    break; // POP B
  case 0xD1:
    stack_pop(state, &state->Register.d, &state->Register.e);
    break; // POP D
  case 0xE1:
    stack_pop(state, &state->Register.h, &state->Register.l);
    break; // POP H
  case 0xF1:
    pop_psw(state);
    break; // POP PSW

  case 0x08:
  case 0x10:
  case 0x18:
  case 0x20:
  case 0x28:
  case 0x30:
  case 0x38:
    nop();
    break; // undocumented NOP

  case 0xCB:
  case 0xD9:
  case 0xDD:
  case 0xED:
  case 0xFD:
    unimplemented(opcode);
    break;
  }
}

void i8080_execute(i8080 *state)
{
  if (state->inte && state->inte_pending)
  {
    state->inte = false;
    state->inte_pending = false;
    state->status = RUNNING;
    i8080_decode(state, state->inte_handle);
  }
  else if (state->status != HALTED)
  {
    u8 opcode = i8080_fetch(state);
    i8080_decode(state, opcode);
  }
}

void i8080_interrupt(struct i8080 *state, u8 opcode)
{
  state->inte_pending = true;
  state->inte_handle = opcode;
}
